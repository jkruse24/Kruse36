#include "kruse36.dtsi"

&default_transform {
    col-offset = <5>;
};

&kscan0 {
    col-gpios = <
        &gpio0 6  GPIO_ACTIVE_HIGH /* Col 0 - Pinky */
        &gpio0 8  GPIO_ACTIVE_HIGH /* Col 1 - Ring */
        &gpio0 17 GPIO_ACTIVE_HIGH /* Col 2 - Middle */
        &gpio0 20 GPIO_ACTIVE_HIGH /* Col 3 - Index */
        &gpio0 22 GPIO_ACTIVE_HIGH /* Col 4 - Inner */
    >;
};
